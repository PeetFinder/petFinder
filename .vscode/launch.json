{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run PetFinder Website",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "powershell",
      "runtimeArgs": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/.vscode/run-petfinder.ps1"
